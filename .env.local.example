# Collabwork Partner API
COLLABWORK_API_KEY=

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: use in API routes / server actions (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set to 1 for full URLs and stack traces in server logs (Vercel / terminal)
# LINK_VALIDATOR_DEBUG=1

# Optional: proxy for Playwright (job clicks) and outbound IP check (same tunnel)
# Use a full URL with credentials, e.g. http://user:pass@proxy.smartproxy.net:3120
# LINK_VALIDATOR_PROXY_URL=

# Optional: URL to resolve egress IP when using a proxy (default: https://api.ipify.org?format=json)
# For plain-text or other JSON shapes, see lib/outbound-ip.ts
# LINK_VALIDATOR_OUTBOUND_IP_URL=https://api.ip.cc

# Collabwork Partner API
COLLABWORK_API_KEY=

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: use in API routes / server actions (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set to 1 for full URLs and stack traces in server logs (Vercel / terminal)
# LINK_VALIDATOR_DEBUG=1

# Optional: proxy for Playwright (job clicks) and outbound IP check (same tunnel)
# Use a full URL with credentials, e.g. http://user:pass@proxy.smartproxy.net:3120
# LINK_VALIDATOR_PROXY_URL=

# Optional: URL to resolve egress IP when using a proxy (default: https://api.ipify.org?format=json)
# For plain-text or other JSON shapes, see lib/outbound-ip.ts
# LINK_VALIDATOR_OUTBOUND_IP_URL=https://api.ip.cc

# Anti-bot / fingerprint (optional): stealth evasions via playwright-extra (default on). Set to 0 to disable.
# LINK_VALIDATOR_STEALTH=0

# Align locale / timezone / viewport with your proxy egress region (reduces geo mismatch vs residential IP).
# LINK_VALIDATOR_BROWSER_LOCALE=en-US
# LINK_VALIDATOR_BROWSER_TIMEZONE=America/New_York
# LINK_VALIDATOR_VIEWPORT_WIDTH=1920
# LINK_VALIDATOR_VIEWPORT_HEIGHT=1080

# Sticky sessions: many providers require a stable session id in the proxy username or URL — use their docs
# and keep one LINK_VALIDATOR_PROXY_URL per logical session so cookies/IP stay consistent across hops.

# Navigation: slow proxies / multi-hop redirects may need more time. Match Vercel function maxDuration on /api/click.
# Residential proxies sometimes return ERR_TUNNEL_CONNECTION_FAILED — we retry; raise attempts if needed.
# LINK_VALIDATOR_GOTO_TIMEOUT_MS=70000
# LINK_VALIDATOR_GOTO_MAX_ATTEMPTS=3
# LINK_VALIDATOR_GOTO_RETRY_BACKOFF_MS=3500

# Chromium on Vercel: if /tmp is tight, launch→newPage may fail; defaults retry up to 4 times with 2000ms backoff.
# LINK_VALIDATOR_BROWSER_SETUP_MAX_ATTEMPTS=4
# LINK_VALIDATOR_BROWSER_SETUP_RETRY_BACKOFF_MS=2000
